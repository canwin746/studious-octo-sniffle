generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique @db.VarChar(50)
  password     String    @db.VarChar(255)
  role         Role      @default(TEACHER)
  email        String?   @unique @db.VarChar(100)
  phone        String?   @unique @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  teacherProfile TeacherProfile?
  adminLogs    AdminLog[]
}

model TeacherProfile {
  id            String     @id @default(cuid())
  userId        String     @unique
  name          String     @db.VarChar(100)
  avatar        String?    @db.Text
  title         String?    @db.VarChar(50)
  department    String     @db.VarChar(100)
  college       String     @db.VarChar(100)
  education     String?    @db.VarChar(50)
  major         String?    @db.VarChar(100)
  hireDate      DateTime?
  abilityRadar  Json       @default("{}")
  tags          Json       @default("[]")
  overallScore  Float      @default(0)
  description   String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses       Course[]
  evaluations   Evaluation[]
  achievements  Achievement[]
  @@index([college])
  @@index([title])
}

model Course {
  id            String     @id @default(cuid())
  name          String     @db.VarChar(100)
  code          String     @db.VarChar(20)
  credit        Float      @default(3)
  semester      String     @db.VarChar(20)
  year          Int
  teacherId     String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  evaluations   Evaluation[]
  @@unique([code, year, semester])
}

model Evaluation {
  id            String     @id @default(cuid())
  type          EvalType  @default(TEACHING)
  score         Float      @default(0)
  comment       String?    @db.Text
  evaluator     String     @db.VarChar(100)
  evaluateDate  DateTime   @default(now())
  teacherId     String
  courseId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  course        Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
}

model Achievement {
  id            String     @id @default(cuid())
  title         String     @db.VarChar(200)
  type          AchieveType
  authors       String     @db.VarChar(500)
  journal       String?    @db.VarChar(200)
  publishDate   DateTime?
  impactFactor  Float?
  level         String?    @db.VarChar(20)
  teacherId     String
  url           String?    @db.VarChar(500)
  summary       String?    @db.Text
  keywords      String?    @db.VarChar(200)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id            String     @id @default(cuid())
  action        String     @db.VarChar(100)
  targetType    String     @db.VarChar(50)
  targetId      String     @db.VarChar(50)
  description   String?    @db.Text
  operatorId    String
  createdAt     DateTime   @default(now())
  operator      User       @relation(fields: [operatorId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum EvalType {
  TEACHING
  RESEARCH
  SERVICE
  COLLABORATION
  INNOVATION
}

enum AchieveType {
  PAPER
  PATENT
  PROJECT
  AWARD
  OTHER
}
